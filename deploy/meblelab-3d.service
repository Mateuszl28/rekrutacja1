[Unit]
Description=MebleLab 3D - sklep meblowy z planerem 3D (Node.js)
After=network.target

[Service]
Type=simple
Environment=PORT=8090
Environment=HOST=0.0.0.0
WorkingDirectory=/opt/meblelab-3d
ExecStart=/usr/bin/node server/index.mjs
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
